{
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/stores/:store/",
      "destination": "/stores/:store",
      "permanent": true
    },
    {
      "source": "/login.html",
      "destination": "/general-stuff/login.html",
      "permanent": true
    },
    {
      "source": "/signup.html",
      "destination": "/general-stuff/signup.html",
      "permanent": true
    },
    {
      "source": "/all-stores.html",
      "destination": "/general-stuff/all-stores.html",
      "permanent": true
    },
    {
      "source": "/login",
      "destination": "/general-stuff/login.html",
      "permanent": true
    },
    {
      "source": "/signup",
      "destination": "/general-stuff/signup.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/stores/:store",
      "destination": "/stores/:store/index.html"
    }
  ]
}
